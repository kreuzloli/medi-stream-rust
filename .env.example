TENCENT_LIVE_PUSH_DOMAIN=push.xxx.com
TENCENT_LIVE_PLAY_DOMAIN=live.xxx.com
TENCENT_LIVE_PUSH_KEY=replace-with-tencent-live-push-key
TENCENT_LIVE_PLAY_KEY=replace-with-tencent-live-play-key
